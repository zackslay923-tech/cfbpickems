rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function submissionsOpen() {
      return !(get(/databases/$(database)/documents/config/app).data.picksLocked == true);
    }

    // Picks: public create/update with code+lastNameLower checks; reads allowed
    match /picks/{pickId} {
      allow get: if true;
      allow list: if true;

      allow create: if (submissionsOpen() || isAdmin())
        && request.resource.data.code is string
        && request.resource.data.code.matches('^[0-9]{6}$')
        && request.resource.data.year is number
        && request.resource.data.week is number
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.lastNameLower is string
        && request.resource.data.phone is string
        && request.resource.data.venmo is string
        && request.resource.data.venmoConfirmed is bool
        && request.resource.data.picks is map;

      allow update: if (submissionsOpen() || isAdmin())
        && request.resource.data.code == resource.data.code
        && request.resource.data.lastNameLower == resource.data.lastNameLower
        && request.resource.data.year == resource.data.year
        && request.resource.data.week == resource.data.week;

      // Real season picks are permanently immutable (no delete, ever, even for admins).
      // Exception: admin-only cleanup of the built-in dummy/test sandbox (year >= 2090),
      // so "Clear Dummy Week" can actually delete its own test picks.
      allow delete: if isAdmin() && resource.data.year is number && resource.data.year >= 2090;
    }

    // Keys: helper collection
    match /keys/{keyId} {
      allow get: if true;
      allow list: if true;
      allow create: if request.resource.data.picksId is string && request.resource.data.picksId.size() > 0;
      allow update: if resource.data.picksId == request.resource.data.picksId;
      allow delete: if false;
    }

    // Games & Results: public read; admin write
    match /games/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config:
    // - cfbd: admin-only read/write (protects API key)
    // - others: public read; admin write
    match /config/cfbd {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /config/{doc=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admins: only the signed-in admin can read their own doc; no writes via client
    match /admins/{uid} {
      allow read: if isAdmin() && request.auth.uid == uid;
      allow write: if false;
    }

    // Public scoreboard: anyone can read; only admins can write
    match /public/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

