function AdminLivePullStatus({ db }) {
  const [lastUpdated, setLastUpdated] = useState(null);
  const [now, setNow] = useState(new Date());

  // Ticks every 30s so the badge stays fresh
  useEffect(() => {
    const t = setInterval(() => setNow(new Date()), 30000);
    return () => clearInterval(t);
  }, []);

  // Subscribe to the most recent results update
  useEffect(() => {
    try {
      const q = query(
        collection(db, "results"),
        orderBy("updatedAt", "desc"),
        limit(1)
      );
      const unsub = onSnapshot(q, (snap) => {
        const d = snap.docs[0]?.data?.();
        // Support serverTimestamp + epoch fallback
        let ts = null;
        if (d?.updatedAt?.toDate) ts = d.updatedAt.toDate();
        else if (d?.updatedAt?.seconds) ts = new Date(d.updatedAt.seconds * 1000);
        setLastUpdated(ts);
      });
      return unsub;
    } catch (e) {
      console.warn("AdminLivePullStatus subscribe failed:", e);
    }
  }, [db]);

  // Only show on admin routes
  const path = (typeof window !== "undefined" && window.location?.pathname) || "";
  const onAdmin = path.startsWith("/admin");

  // ET helpers
  function nowInETParts(dateObj) {
    const etStr = dateObj.toLocaleString("en-US", { timeZone: "America/New_York" });
    const et = new Date(etStr);
    const weekday = et.toLocaleDateString("en-US", { weekday: "long" });
    const hour = et.getHours();
    const minute = et.getMinutes();
    return { et, weekday, hour, minute };
  }
  function withinWindowET(dateObj) {
    const { weekday, hour, minute } = nowInETParts(dateObj);
    if (weekday === "Saturday") {
      if (hour > 13) return true;           // after 1pm
      if (hour === 13 && minute >= 30) return true; // 1:30pm onward
      return false;
    }
    if (weekday === "Sunday" && hour < 3) return true; // until 2:59am
    return false;
  }
  function formatET(d) {
    if (!d) return "—";
    return d.toLocaleString("en-US", {
      timeZone: "America/New_York",
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
      second: "2-digit",
      hour12: true,
    });
  }

  const inside = withinWindowET(now);
  let status = "Outside window";
  if (inside) {
    const mins = lastUpdated ? Math.round((now - lastUpdated) / 60000) : null;
    status = mins !== null && mins <= 5 ? "Active" : "Idle";
  }

  if (!onAdmin) return null;

  return (
    <div
      style={{
        position: "fixed",
        right: 16,
        bottom: 16,
        zIndex: 50_000,
        background: "rgba(17,24,39,0.9)",      // slate-900/90
        color: "white",
        borderRadius: 12,
        padding: "10px 12px",
        boxShadow: "0 4px 24px rgba(0,0,0,0.35)",
        backdropFilter: "blur(6px)",
        fontSize: 14,
        lineHeight: 1.25,
      }}
      aria-live="polite"
      aria-label="Live results status"
    >
      <div style={{ fontWeight: 600, marginBottom: 4 }}>Live Results</div>
      <div><span style={{ opacity: 0.8 }}>Status:</span> {status}</div>
      <div><span style={{ opacity: 0.8 }}>Last Updated:</span> {formatET(lastUpdated)}</div>
    </div>
  );
}



