const FBS_CONF = new Set([
  "ACC","American Athletic","American","Big 12","Big Ten",
  "Conference USA","CUSA","Mid-American","MAC","Mountain West","Pac-12","SEC","Sun Belt",
  "FBS Independents","Independent","Independents"
